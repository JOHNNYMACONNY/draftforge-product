      "sourceType": "photos",
      "sourceName": "Sample_Studio",
      "assetId": "photos:sample:image-001",
      "originalMediaKind": "image",
      "outputMediaKind": "video",
      "outputPath": "media/01_card.mp4",
      "durationSeconds": 6.5,
      "width": 1080,
      "height": 1350,
      "audioMode": "local",
      "musicTrackPath": "music/redacted-track-01.mp3",
      "musicOffsetSeconds": 12,
      "verification": {
        "hasVideo": true,
        "hasAudio": true,
        "codecVideo": "h264",
        "codecAudio": "aac"
      }
    },
    {
      "order": 2,
      "sourceType": "photos",
      "sourceName": "Sample_Studio",
      "assetId": "photos:sample:video-001",
      "originalMediaKind": "video",
      "outputMediaKind": "video",
      "outputPath": "media/02_card.mp4",
      "durationSeconds": 12,
      "width": 1080,
      "height": 1350,
      "audioMode": "local",
      "musicTrackPath": "music/redacted-track-02.mp3",
      "musicOffsetSeconds": 24,
      "verification": {
        "hasVideo": true,
        "hasAudio": true,
        "codecVideo": "h264",
        "codecAudio": "aac"
      }
    }
  ],
  "outputs": {
    "mediaDir": "media",
    "captionPath": "caption.txt",
    "reviewPath": "review.md",
    "previewPath": "preview.html"
